PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/yoga_booking?retryWrites=true&w=majority

JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars
JWT_REFRESH_SECRET=another_secret_for_refresh_32_chars

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL via Brevo (Railway blocks SMTP — Brevo uses HTTPS API, always works)
# Free plan: 300 emails/day, sends to ANY recipient, no domain needed
#
# Setup (3 minutes):
#  1. Go to https://app.brevo.com  →  sign up free
#  2. Top-right → My Account → SMTP & API  →  API Keys tab
#  3. Generate a new API Key  →  copy it below
# ─────────────────────────────────────────────────────────────────────────────
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From address shown in emails (use any display name you like)
EMAIL_FROM=YogaFlow <hello@yogaflow.in>

FRONTEND_URL=http://localhost:5173
ADMIN_SECRET_KEY=your_admin_secret_key
OTP_EXPIRE_MINUTES=10
