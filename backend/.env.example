# ─────────────────────────────────────────────
#  YOGA BOOKING APP — ENVIRONMENT VARIABLES
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/yoga_booking?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRE=30d

# Email (Gmail SMTP — use App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=YogaFlow <your.email@gmail.com>

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173

# Admin
ADMIN_EMAIL=admin@yogaflow.com
ADMIN_SECRET_KEY=create_admin_secret_key

# OTP expiry in minutes
OTP_EXPIRE_MINUTES=10
